# *****
# Utility
# *****

# replace dir with better printing
dir() {
    if [[ $# -ne 1 ]]; then
        tree -Cfsh --noreport --dirsfirst
    else
        tree -Cfsh --noreport --dirsfirst $1
    fi
}

# sort file by frequency 
mode() {
    sort -T ./ | uniq -c | sort -nr -T ./
}

# only print new lines not in file
onlynew() {
    if [[ $# -ne 1 ]]; then
        echo 'only print new items not in file'
        echo 'EXAMPLE: onlynew <FILE>'
    else
        awk 'FNR==NR {a[$0]++; next} !($0 in a)' $1 -
    fi 
}

# unqiue sort file
usort() {
    if [[ $# -ne 1 ]]; then
        echo 'unique sort file inplace'
        echo 'EXAMPLE: usort <FILE>'
    else
        LC_ALL=C sort -u $1 -T ./ -o $1
    fi
}

# shuffle file file inplace
ishuf() {
    if [[ $# -ne 1 ]]; then
        echo 'shuffle file inplace'
        echo 'EXAMPLE: ishuf <FILE>'
    else
        shuf -o $1 < $1
    fi
}

# tmux wrapper
tmuxx() {
    if [[ $# -ne 1 ]]; then
        tmux attach
    else
        tmux new -s $1
    fi
}

# removes color from stdin or inplace with a file                                                                                                                                                                                                                   
nocolor(){
    if [[ $# -ne 1 ]]; then
        sed 's/\x1B\[[0-9;]\{1,\}[A-Za-z]//g'
    else
        sed -i 's/\x1B\[[0-9;]\{1,\}[A-Za-z]//g' $1
    fi
}

# finds non-printable characters
noprint(){
    if [[ $# -ne 1 ]]; then
        grep '[^[:print:]]'
    else
        grep '[^[:print:]]' $1
    fi
}

# removes case from stdin or file and prints to stdout
tolower(){
    if [[ $# -ne 1 ]]; then
        awk '{print tolower($0)}'
    else
        awk '{print tolower($0)}' $1
    fi
}

