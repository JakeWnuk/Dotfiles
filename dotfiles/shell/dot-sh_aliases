dk-here(){
    if [[ $# -lt 1 ]]; then
        tput setaf 2;echo 'EXAMPLE: dk-here IMAGE+ARGS'
        echo ''
        docker image ls
        echo ''
    else
        docker run -it --rm --volume ${PWD}:/data "$@"
