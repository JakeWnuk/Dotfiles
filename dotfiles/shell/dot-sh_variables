bshtxtcyn='\[\e[0;36m\]' # Cyan
bshtxtwht='\[\e[0;37m\]' # White
bshtxtrst='\[\e[0m\]'    # Text Reset

# For Bash PS1
atC="${bshtxtgrn}"
nameC="${bshtxtcyn}"
