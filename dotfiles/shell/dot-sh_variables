# Bash Colors
bshtxtblk='\[\e[0;30m\]' # Black
bshtxtred='\[\e[0;31m\]' # Red
bshtxtgrn='\[\e[0;32m\]' # Green
bshtxtylw='\[\e[0;33m\]' # Yellow
